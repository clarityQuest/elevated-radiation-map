<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground: blue map-pin with ISO radiation trefoil.
  108×108dp canvas. Trefoil centred at (54,42) inside the dark inner disc.

  ISO 21482 trefoil construction (one blade points DOWN):
    R = 2.8dp (unit)
    Centre dot radius   = R     = 2.8
    Blade inner radius  = 1.5R  = 4.2
    Blade outer radius  = 5R    = 14.0
    Each blade = 60° arc, gaps = 60° between blades.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Blue map-pin teardrop -->
    <path
        android:fillColor="#378ADD"
        android:pathData="
          M54,22
          C42.95,22 34,30.95 34,42
          C34,56 54,82 54,82
          C54,82 74,56 74,42
          C74,30.95 65.05,22 54,22 Z"/>

    <!-- Inner circle filled with navy (the background colour) -->
    <path
        android:fillColor="#1a1a2e"
        android:pathData="
          M54,30
          C47.37,30 42,35.37 42,42
          C42,48.63 47.37,54 54,54
          C60.63,54 66,48.63 66,42
          C66,35.37 60.63,30 54,30 Z"/>

    <!-- Blade 1: DOWN (60° to 120°) -->
    <path
        android:fillColor="#FFD600"
        android:pathData="
          M56.10,45.64
          L61.00,54.12
          A14,14 0 0,1 47.00,54.12
          L51.90,45.64
          A4.2,4.2 0 0,0 56.10,45.64
          Z"/>

    <!-- Blade 2: UPPER-LEFT (180° to 240°) -->
    <path
        android:fillColor="#FFD600"
        android:pathData="
          M49.80,42.00
          L40.00,42.00
          A14,14 0 0,1 47.00,29.88
          L51.90,38.36
          A4.2,4.2 0 0,0 49.80,42.00
          Z"/>

    <!-- Blade 3: UPPER-RIGHT (300° to 360°) -->
    <path
        android:fillColor="#FFD600"
        android:pathData="
          M56.10,38.36
          L61.00,29.88
          A14,14 0 0,1 68.00,42.00
          L58.20,42.00
          A4.2,4.2 0 0,0 56.10,38.36
          Z"/>

    <!-- Centre dot -->
    <path
        android:fillColor="#FFD600"
        android:pathData="
          M56.8,42
          A2.8,2.8 0 0,1 51.2,42
          A2.8,2.8 0 0,1 56.8,42 Z"/>

</vector>
